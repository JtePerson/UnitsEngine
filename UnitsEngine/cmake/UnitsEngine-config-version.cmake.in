set(UnitsEngine_PACKAGE_VERSION        @UnitsEngine_PACKAGE_VERSION@)
# Store the major in the file so we can compare at use time
string(REGEX MATCH "^([0-9]+)" UnitsEngine_VERSION_MAJOR ${UnitsEngine_PACKAGE_VERSION})

# Default outcomes
set(UnitsEngine_PACKAGE_VERSION_COMPATIBLE FALSE)
set(UnitsEngine_PACKAGE_VERSION_EXACT FALSE)

if(NOT DEFINED UnitsEngine_PACKAGE_FIND_VERSION)
    # No specific version requested -> compatible by default
    set(UnitsEngine_VERSION_COMPATIBLE TRUE)
else()
    # Compare major-only for compatibility
    if(DEFINED UnitsEngine_PACKAGE_FIND_VERSION_MAJOR)
        if(${UnitsEngine_PACKAGE_FIND_VERSION_MAJOR} STREQUAL ${UnitsEngine_PACKAGE_VERSION_MAJOR})
            set(UnitsEngine_PACKAGE_VERSION_COMPATIBLE TRUE)
        endif()
    else()
        # If CMake didn't compute UnitsEngine_FIND_VERSION_MAJOR, try parsing it
        string(REGEX MATCH "^([0-9]+)" _req_major ${UnitsEngine_PACKAGE_FIND_VERSION})
        if(${_req_major} STREQUAL ${UnitsEngine_PACKAGE_VERSION_MAJOR})
            set(UnitsEngine_PACKAGE_VERSION_COMPATIBLE TRUE)
        endif()
    endif()

    # Exact match check
    if(${UnitsEngine_PACKAGE_FIND_VERSION} STREQUAL ${UnitsEngine_PACKAGE_VERSION})
        set(UnitsEngine_PACKAGE_VERSION_EXACT TRUE)
    endif()
endif()